{
    "buildCommand":  "pnpm run build",
    "outputDirectory":  "dist",
    "installCommand":  "pnpm install",
    "framework":  "vite",
    "cleanUrls":  true,
    "rewrites":  [
                     {
                         "source":  "/((?!.*\\.(png|jpg|jpeg|gif|svg|ico|css|js|woff|woff2|ttf|eot|json|webp)).*)",
                         "destination":  "/index.html"
                     }
                 ],
    "_comment":  "Vercel deployment trigger"
}
